# Binance USDT-M futures (the binance app: `python -m binance.main --trade`)
BINANCE_API_KEY=your-binance-key
BINANCE_API_SECRET=your-binance-secret

# OKX USDT perpetual swaps (the okx app: `python -m okx.main --trade`)
